@startuml
title Kagi R Client — Class Diagram (S3-style)

skinparam classAttributeIconSize 0

class "kagi_connection" as KConn {
  + base_url : character(1)
  + endpoint : character(1)
  + api_key  : character(1)
}

class "kagi_search" as KSearch {
  + conn   : kagi_connection
  + params : list(q, limit?)
}

class "kagi_search_results" as KSearchRes {
  + search   : kagi_search
  + raw_json : character(1)
  + meta     : list
  + data     : list  // t==0 hits, t==1 related
}

class "summarizer_request" as SumReq {
  + conn   : kagi_connection
  + params : list(url? | text?, engine?, summary_type?, target_language?, cache?)
}

class "summarizer_results" as SumRes {
  + request  : summarizer_request
  + raw_json : character(1)
  + meta     : list
  + data     : list  // output, tokens
}

class "kagi_req_build()" as ReqBuild <<function>>
class "kagi_perform()" as KPerform <<generic>>
class "summarizer_perform()" as SPerform <<generic>>
class "kagi_hits()" as KHits <<generic>>
class "kagi_related()" as KRel <<generic>>
class "kagi_meta()" as KMeta <<generic>>
class "summarizer_output()" as SOut <<generic>>
class "summarizer_tokens()" as STok <<generic>>
class "%||%" as OrOp <<utility>>
class "compact_list()" as Compact <<utility>>

KSearch --> KConn : has
KSearchRes --> KSearch : wraps
SumReq --> KConn : has
SumRes --> SumReq : wraps

ReqBuild --> KConn : builds request from

KPerform --> KSearch : method kagi_perform.kagi_search
KHits --> KSearchRes : method kagi_hits.kagi_search_results
KRel  --> KSearchRes : method kagi_related.kagi_search_results
KMeta --> KSearchRes : method kagi_meta.kagi_search_results

SPerform --> SumReq : method summarizer_perform.summarizer_request
SOut --> SumRes : method summarizer_output.summarizer_results
STok --> SumRes : method summarizer_tokens.summarizer_results

OrOp ..> KSearch
OrOp ..> KSearchRes
OrOp ..> SumReq
OrOp ..> SumRes
Compact ..> SumReq

@enduml